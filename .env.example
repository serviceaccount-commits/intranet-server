# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                  # development | production

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=your_db_name

# ─── MongoDB (Knowledge Base) ─────────────────────────────────────────────────
# Run: npm run db:up  (starts MongoDB via Docker)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=paricus_kb

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
GEMINI_AI_API_KEY=your_gemini_api_key

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
GOOGLE_APPLICATION_CREDENTIALS=./config/service-account.json

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_PATH=./private.pem
JWT_PUBLIC_KEY_PATH=./public.pem
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRATION=1200      # seconds (20 min)
JWT_REFRESH_TOKEN_EXPIRATION=86400    # seconds (1 day)
JWT_ISSUER=Paricus
JWT_AUDIENCE=IntranetApp

JWT_VERIFY_EMAIL_PRIVATE_KEY_PATH=./verify_email_private.pem
JWT_VERIFY_EMAIL_EXPIRATION=86400
JWT_VERIFY_EMAIL_AUDIENCE=https://api.myparicus.paricus.com/api/v1/auth/verify-email

# ─── App ──────────────────────────────────────────────────────────────────────
COOKIE_SECRET=change_this_to_a_strong_random_secret
INTERNAL_API_KEY=change_this_to_a_strong_random_key
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
