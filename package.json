{
  "name": "intranet-server",
  "version": "1.0.0",
  "description": "server side app",
  "main": "index.js",
  "scripts": {
    "build": "node --max-old-space-size=1450 node_modules/typescript/bin/tsc",
    "dev": "nodemon ./src/server.ts",
    "start": "node dist/server.js",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f mongodb",
    "lint": "eslint . --ext .ts,.js",
    "lint:fix": "eslint . --ext .ts,.js --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "m:run": "npx typeorm-ts-node-commonjs migration:run -d src/shared/database/data-source.ts",
    "m:generate": "npx typeorm-ts-node-commonjs migration:generate src/shared/database/migrations/migration -d src/shared/database/data-source.ts",
    "m:revert": "npx typeorm-ts-node-commonjs migration:revert -d src/shared/database/data-source.ts",
    "seed:permissions": "ts-node src/shared/database/seeds/seed-permissions.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.13.5",
    "@tsconfig/node-lts": "22.0.1",
    "@types/cheerio": "^0.22.35",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jsonwebtoken": "9.0.9",
    "@types/morgan": "1.9.9",
    "@types/multer": "1.4.12",
    "@types/node": "22.13.9",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/pg": "^8.20.0",
    "@types/socket.io": "^3.0.1",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.0.2",
    "eslint-plugin-prettier": "^5.2.3",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "10.9.2",
    "typescript": "5.8.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.882.0",
    "@aws-sdk/s3-request-presigner": "^3.884.0",
    "@google/generative-ai": "^0.24.1",
    "@types/uuid": "^10.0.0",
    "body-parser": "1.20.3",
    "cheerio": "^1.1.2",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "date-fns-tz": "3.2.0",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "googleapis": "^164.0.0",
    "inversify": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "mongodb": "^5.9.2",
    "morgan": "^1.10.1",
    "multer": "1.4.5-lts.2",
    "node-cron": "^4.2.1",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "pg": "8.13.3",
    "pgvector": "^0.2.1",
    "reflect-metadata": "0.2.2",
    "socket.io": "4.8.1",
    "typeorm": "0.3.21",
    "uuid": "^11.1.0",
    "zod": "3.24.2"
  }
}
